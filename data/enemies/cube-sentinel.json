      "telegraphDuration": 500,
      "activeDuration": 100,
      "recoveryDuration": 800,
      "damage": 12,
      "staggerDamage": 5,
      "range": 15,
      "hitboxShape": "sphere",
      "hitboxSize": { "radius": 0.3 },
      "movementDuringAttack": null,
      "projectile": {
        "shape": "cube",
        "speed": 10,
        "lifetime": 2000,
        "size": 0.2,
        "homing": false
      }
    },
    {
      "id": "scatter_shot",
      "name": "Scatter Shot",
      "telegraphDuration": 700,
      "activeDuration": 100,
      "recoveryDuration": 1200,
      "damage": 8,
      "staggerDamage": 3,
      "range": 12,
      "hitboxShape": "sphere",
      "hitboxSize": { "radius": 0.25 },
      "movementDuringAttack": null,
      "projectile": {
        "shape": "cube",
        "speed": 10,
        "lifetime": 2000,
        "size": 0.15,
        "homing": false
      }
    }
