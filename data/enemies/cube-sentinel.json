  "drops": {
    "shards": { "min": 2, "max": 5 },
    "fragmentChance": 0.08
  },
  "fsm": {
    "initialState": "idle",
    "states": [
      {
        "name": "idle",
        "transitions": [
          { "to": "alert", "condition": "playerInAggroRange" }
        ]
      },
      {
        "name": "alert",
        "transitions": [
          { "to": "attack", "condition": "playerInAttackRange" },
          { "to": "idle", "condition": "playerOutOfAggroRange" },
          { "to": "retreat", "condition": "playerTooClose" }
        ]
      },
      {
        "name": "attack",
        "params": { "attackPool": ["shard_bolt", "scatter_shot"], "attackCooldown": 600 },
        "transitions": [
          { "to": "retreat", "condition": "playerTooClose" },
          { "to": "alert", "condition": "attackComplete_and_playerOutOfAttackRange" }
        ]
      },
      {
        "name": "retreat",
        "params": { "targetDistance": 10 },
        "transitions": [
          { "to": "attack", "condition": "atTargetDistance_and_playerInAttackRange" },
          { "to": "alert", "condition": "atTargetDistance" }
        ]
      },
      {
        "name": "staggered",
        "params": { "duration": 800 },
        "transitions": [
          { "to": "alert", "condition": "staggerComplete" }
        ]
      }
    ]
  }
